# ── Server ───────────────────────────────────────────────
PORT=3001

# PostgreSQL — החלף YOUR_PASSWORD בסיסמת ה-postgres שלך
DB_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/usejetlag

JWT_SECRET=choose_any_long_random_string_here
CLIENT_URL=http://localhost:5173

# ── Cloudinary ───────────────────────────────────────────
# https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── OpenAI ───────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── OpenWeather ──────────────────────────────────────────
# https://openweathermap.org/api → Free plan
OPENWEATHER_API_KEY=your_weather_key

# ── Client ───────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
